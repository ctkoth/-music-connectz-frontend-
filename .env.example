# Music ConnectZ — Frontend Environment Variables
# Copy to .env.local and fill in. .env.local is gitignored.

# Backend API base URL. Leave blank to run in localStorage-only demo mode.
# Local dev:    http://localhost:8000
# Production:   https://music-connectz-backend-2.onrender.com
VITE_API_BASE=

# Optional: direct Anthropic key for OCC/RateZ/Parcel Primate when running
# without backend. PRODUCTION: leave blank and let backend proxy these calls.
VITE_ANTHROPIC_KEY=

# Optional: Stripe publishable key for client-side checkout redirects
VITE_STRIPE_PUBLISHABLE_KEY=
